{
  "appId": "com.yourcompany.intentflow",
  "appName": "IntentFlow",
  "webDir": "out",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "iosScheme": "ionic"
  },
  "plugins": {
    "CapacitorSQLite": {
      "iosDatabaseLocation": "Library/CapacitorDatabase",
      "androidIsEncryption": false,
      "electronIsEncryption": false
    },
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0047AB"
    }
  }
}
