{
  "name": "intentflow",
  "version": "1.0.0",
  "description": "Money Manager Desktop - Zero-based budgeting app",
  "main": "src/main/index.cjs",
  "sideEffects": [
    "**/*.css",
    "**/*.scss",
    "**/*.less",
    "**/*.module.css",
    "./src/components/Sidebar/**",
    "./src/styles/**",
    "./src/components/**/*.css",
    "./src/pages/**/*.css"
  ],
  "scripts": {
    "migrate": "node src/db/migrations/run.cjs",
    "migrate:check": "sqlite3 ~/Library/Application\\ Support/intentflow/database/app.db \"PRAGMA table_info(categories);\"",
    "dist": "npm run clean && npm run build && npm run verify-build && electron-builder",
    "verify-build": "echo '✅ Verifying build output:' && ls -la out/ && echo 'out folder exists with files'",
    "postbuild": "echo '✅ Build complete, out folder contains:' && ls -la out/",
    "next-dev": "next dev",
    "next-build": "next build",
    "build": "next build",
    "start": "cross-env NODE_ENV=development electron .",
    "dev": "concurrently \"npm run next-dev\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "electron": "electron .",
    "electron-dev": "cross-env NODE_ENV=development electron .",
    "dist:mac": "npm run clean && npm run build && npm run verify-build && electron-builder --mac",
    "dist:win": "npm run clean && npm run build && npm run verify-build && electron-builder --win",
    "dist:linux": "npm run clean && npm run build && npm run verify-build && electron-builder --linux",
    "clean": "rimraf .next out release dist"
  },
  "keywords": [
    "budget",
    "finance",
    "electron",
    "nextjs",
    "SoulFunds",
    "money-manager"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.intentflow.moneymanager",
    "productName": "Money Manager",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "src/db/data/**/*",
      "src/preload/**/*",
      "src/main/**/*",
      "src/services/**/*",
      "src/services/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "target": "dmg"
    }
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "crypto-js": "^4.2.0",
    "electron-context-menu": "^4.0.0",
    "electron-devtools-installer": "^4.0.0",
    "electron-log": "^5.2.3",
    "electron-serve": "^2.0.0",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^9.0.0",
    "electron-updater": "^6.3.9",
    "next": "^14.2.3",
    "palid": "^0.5.2",
    "plaid": "^41.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "uuid": "^9.0.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "css-minimizer-webpack-plugin": "^7.0.4",
    "cssnano": "^7.1.3",
    "dotenv": "^17.3.1",
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "mini-css-extract-plugin": "^2.10.1",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.8",
    "postcss-discard-comments": "^7.0.6",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.19",
    "terser-webpack-plugin": "^5.3.11",
    "wait-on": "^7.2.0"
  }
}
