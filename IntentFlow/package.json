{
  "name": "intentflow",
  "version": "1.0.0",
  "description": "Money Manager Desktop - Zero-based budgeting app",
  "main": "src/main/index.cjs",
  "type": "commonjs",
  "scripts": {
    "clean": "rimraf .next out release dist",
    "build": "next build",
    "dist": "npm run clean && npm run build && electron-builder",
    "start": "NODE_ENV=production electron .",
    "dev": "concurrently \"next dev\" \"wait-on http://localhost:3000 && electron .\""
  },
  "build": {
    "appId": "com.intentflow.moneymanager",
    "productName": "Money Manager",
    "directories": {
      "output": "release"
    },
    "asarUnpack": [
      "**/*.node"
    ],
    "files": [
      "out/**/*",
      "src/main/**/*",
      "src/preload/**/*",
      "src/db/**/*",
      "src/views/**/*",
      "src/services/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "src/db/data/",
        "to": "db/data/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns",
      "category": "public.app-category.finance"
    }
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.3.1",
    "electron-context-menu": "^4.0.0",
    "electron-log": "^5.2.3",
    "electron-serve": "^2.0.0",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^9.0.0",
    "electron-updater": "^6.3.9",
    "next": "^14.2.3",
    "plaid": "^41.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "uuid": "^9.0.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "css-minimizer-webpack-plugin": "^7.0.4",
    "cssnano": "^7.1.3",
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1",
    "mini-css-extract-plugin": "^2.10.1",
    "postcss": "^8.5.8",
    "postcss-discard-comments": "^7.0.6",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.19",
    "terser-webpack-plugin": "^5.3.11",
    "wait-on": "^9.0.4"
  }
}