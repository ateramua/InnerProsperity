{
	"appId": "com.abdi.intentflow",
	"appName": "IntentFlow",
	"webDir": "out",
	"bundledWebRuntime": false,
	"server": {
		"androidScheme": "https",
		"iosScheme": "ionic"
	},
	"ios": {
		"contentInset": "always",
		"scrollEnabled": true
	},
	"plugins": {
		"CapacitorSQLite": {
			"iosDatabaseLocation": "Library/CapacitorDatabase",
			"iosIsEncryption": false,
			"androidIsEncryption": false
		},
		"SplashScreen": {
			"launchShowDuration": 3000,
			"launchAutoHide": true,
			"backgroundColor": "#0047AB",
			"showSpinner": true,
			"spinnerColor": "#ffffff",
			"splashFullScreen": true,
			"splashImmersive": true
		},
		"StatusBar": {
			"style": "DARK",
			"backgroundColor": "#0047AB"
		},
		"CapacitorUpdater": {
			"appId": "com.abdi.intentflow",
			"autoUpdate": true,
			"version": "1.0.0"
		}
	},
	"packageClassList": [
		"CapacitorSQLitePlugin",
		"AppPlugin",
		"DevicePlugin",
		"HapticsPlugin",
		"KeyboardPlugin",
		"PreferencesPlugin",
		"SplashScreenPlugin",
		"StatusBarPlugin",
		"CapacitorUpdaterPlugin"
	]
}
