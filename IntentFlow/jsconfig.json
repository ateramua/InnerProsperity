{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@components/*": ["./src/components/*"],
      "@styles/*": ["./src/styles/*"],
      "@assets/*": ["./src/assets/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@utils/*": ["./src/utils/*"],
      "@contexts/*": ["./src/contexts/*"]
    },
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM", "DOM.Iterable", "ESNext"],
    "jsx": "react",
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "isolatedModules": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "preserveSymlinks": true
  },
  "include": [
    "src/**/*",
    "*.js",
    "*.jsx",
    "electron/**/*",
    "main/**/*",
    "preload/**/*"
  ],
  "exclude": [
    "node_modules",
    "out",
    ".next",
    "dist",
    "build",
    "release",
    "app-builds"
  ]
}